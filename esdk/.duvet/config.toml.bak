'$schema' = "https://awslabs.github.io/duvet/config/v0.4.0.json"

[[source]]
pattern = "./src/**/*.rs"

[[specification]]
source = "../specification/data-format/message-header.md"

[[specification]]
source = "../specification/data-format/message-footer.md"

[[specification]]
source = "../specification/data-format/message-body.md"

[[specification]]
source = "../specification/data-format/message-body-aad.md"

[[specification]]
source = "../specification/data-format/message.md"

[report.html]
enabled = true

# Enable snapshots to prevent requirement coverage regressions
[report.snapshot]
enabled = false
